+
+func isDarwinVirtualInterface(name string) bool {
+	return strings.HasPrefix(name, "utun") ||
+		strings.HasPrefix(name, "tun") ||
+		strings.HasPrefix(name, "tap") ||
+		strings.HasPrefix(name, "ppp") ||
+		strings.HasPrefix(name, "ipsec")
+}
